{
  "expo": {
    "name": "SOSIFY",
    "slug": "sosify-app",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-peripheral",
          "processing"
        ],
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to discover nearby peers for peer-to-peer messaging.",
        "NSBluetoothPeripheralUsageDescription": "This app advertises as a Bluetooth peripheral so other devices can discover it."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#000000"
      },
      "icon": "./assets/images/icon.png",
      "package": "com.mojojojoo.sosifyapp"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "backgroundColor": "#000000"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "The app accesses your camera to let you take photos and share them with your contacts.",
          "microphonePermission": "The app accesses your microphone to let you record videos."
        }
      ]
    ]
  }
}
