# =====================================================================
# SOSIFY (Disaster P2P Monorepo) — Environment Configuration Template
# Copy this file to .env before running backend services locally.
# =====================================================================

# --- Backend Database Connection Strings ---
# PostgreSQL: Stores user identity profiles and structured incident reports
POSTGRES_URL=postgresql://user:password@localhost:5432/disaster_p2p

# MongoDB: Stores raw, high-throughput unstructured P2P message history archive
MONGO_URL=mongodb://localhost:27017/disaster_p2p

# Redis: Stores ephemeral mesh reachability heartbeats and active rescuer status
REDIS_URL=redis://localhost:6379

# --- Mobile Application Configurations ---
# Currently no secret environment variables required for offline mobile client.
