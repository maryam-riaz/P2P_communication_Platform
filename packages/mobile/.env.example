# Supabase project credentials
# Copy this file to .env and fill in your values.
# Get these from your Supabase dashboard: Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Ed25519 public key used to verify offline role credential signatures.
# Generate with: node -e "console.log(require('tweetnacl').sign.keyPair().publicKey.toString('base64'))"
# This is the PUBLIC half of the keypair used by the Supabase Edge Function sign-credential.
# Bake this into the build so credentials can be verified without internet.
CREDENTIAL_PUBLIC_KEY=
